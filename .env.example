# GEMINI_API_KEY: Optional. Set in HF Spaces Settings → Secrets if needed.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# RENDER_VISION_API_URL: The Python ML backend URL.
# In the Docker container, this defaults to http://localhost:8000 (co-located).
# Only change this if you want to use an external ML backend.
RENDER_VISION_API_URL="http://localhost:8000"

# PORT: The port the Node.js server listens on.
# HF Spaces expects 7860. Do not change unless you know what you're doing.
PORT=7860
